# ── Typhoon OCR (required for ocr.py / ocr_processor.py) ─────────
TYPHOON_API_KEY=your_API_key_here

# ── Database (used by Docker; XAMPP uses localhost defaults) ─────
DB_HOST=db
DB_NAME=exam_ocr
DB_USER=root
DB_PASSWORD=rootpass
DB_CHARSET=utf8mb4

# ── Python binary inside Docker container ────────────────────────
PYTHON_BIN=/opt/venv/bin/python

# ── Base URL (used for auto-grade HTTP trigger) ──────────────────
APP_URL=http://localhost:8080
